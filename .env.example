# Скопируйте в .env и при необходимости измените пароль.
# Для docker compose имя хоста БД — db.

POSTGRES_USER=onit
POSTGRES_PASSWORD=onit_local_password
POSTGRES_DB=onitdb

# Строка для приложения в Docker задаётся в docker-compose (хост db).
# Для pytest с хоста используйте, например:
# set DATABASE_URL=postgresql://onit:onit_local_password@127.0.0.1:5433/onitdb
